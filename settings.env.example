# Optional, signed URL TTLs (seconds) and server-side cache fraction
#SIGNED_URL_TTL_SECONDS=14400           # gallery/static URLs
#SIGNED_DOWNLOAD_URL_TTL_SECONDS=900    # one-shot download links
#SIGNED_META_URL_TTL_SECONDS=86400      # OG/social-card URLs (scrapers cache for hours)
#SIGNED_URL_REFRESH_RATIO=0.5           # cache TTL = signing TTL * ratio

# Optional, upload limits. UPLOAD_MAX_SIZE (digits + K/M/G, nginx syntax) is
# enforced by nginx, the app, and the upload UI from this single value.
# Local storage transiently needs ~2-3x the file size in container disk.
# UPLOAD_MAX_IMAGE_PIXELS caps in-request image processing (EXIF/thumbnails);
# larger images upload fine but skip processing. Default 0 auto-derives the
# budget from the container memory limit (unlimited when no limit is set).
#UPLOAD_MAX_SIZE=5G
#UPLOAD_MAX_IMAGE_PIXELS=0

# Optional, tus resumable uploads. On by default — every image runs tusd
# (local process in the all-in-one image, sidecar container in the compose
# stacks). Switches the web uploader to chunked uploads at /tus/ — chunks
# pass Cloudflare's 100MB request-body cap and dropped transfers resume.
# Abandoned partial uploads are swept after TUS_EXPIRE_HOURS.
# Set TUS_ENABLED=False only for a custom deployment that doesn't run tusd.
# TUS_CHUNK_MB is the client-side chunk size; 90 stays under Cloudflare
# Free/Pro's 100MB request-body cap with headroom, raise it if that cap
# doesn't apply to you. TUS_HOOK_SECRET guards the internal tusd->app hook
# endpoint; leave it unset to use the secret auto-generated on the shared
# volume at startup. TUS_DISK_HEADROOM_MB is the minimum free space the media
# volume must have left after a declared upload completes — rejected upfront
# if it wouldn't. See docs/resource-sizing.md for how to size all of this.
#TUS_ENABLED=False
#TUS_CHUNK_MB=90
#TUS_EXPIRE_HOURS=24
#TUS_HOOK_SECRET=
#TUS_DISK_HEADROOM_MB=1024

# Optional, Celery worker resource guards. File processing (image/video
# decode, storage copy) scales with whatever a user uploads, so these bound
# the blast radius: a worker child is recycled once it holds onto this much
# RSS, and any single task is killed if it runs unreasonably long instead of
# parking a worker slot forever. See docs/resource-sizing.md.
#CELERY_WORKER_MAX_MEMORY_PER_CHILD_KB=1048576
#CELERY_TASK_SOFT_TIME_LIMIT=1500
#CELERY_TASK_TIME_LIMIT=1800

# ONLY for Amazon S3 Storage Backend

#AWS_REGION_NAME=
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_STORAGE_BUCKET_NAME=
#AWS_S3_CDN_URL='https://mycloudflareorcloudfrontdomain.com'

# ONLY for Duo Two Factor Auth

DUO_API_HOST=
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=

# ONLY for using 'mysql' or 'postgres' database (not provided)

DATABASE_TYPE=sqlite3
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASS=
DATABASE_HOST=
DATABASE_PORT=

# ONLY to configure sentry

SENTRY_URL=
SENTRY_SAMPLE_RATE=0.1
SENTRY_DEBUG=False
SENTRY_ENVIRONMENT=prod

# ONLY for advanced logging configuration

APP_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING

# ADVANCED DJANGO configuration only below, DO NOT EDIT

#DATABASE_LOCATION=/data/media/db/database.sqlite3
NGINX_ACCESS_LOGS=/logs/nginx.access
DISABLE_DEBUG_TOOLBAR=False

DEBUG=False
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=
SESSION_COOKIE_AGE=1209600
#STATIC_ROOT=/data/static
#MEDIA_ROOT=/data/media/files
#USE_TZ=True
LANGUAGE_CODE=en-us
TZ=UTC

USE_X_FORWARDED_HOST=True
SECURE_REFERRER_POLICY=no-referrer-when-downgrade

CACHE_BACKEND=django_redis.cache.RedisCache
CACHE_LOCATION=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_IGNORE_EXCEPTIONS=True


# Allow setting a custom RTMP_HOST so RTMP link generation can use instead of CDN fronted domains
RTMP_HOST=my-df-server.example.com